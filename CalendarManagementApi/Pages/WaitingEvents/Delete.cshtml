@page "{id:int}"
@model CalendarManagementApi.Pages.WaitingEvents.DeleteModel
@{
    ViewData["Title"] = "Delete Waiting Event";
}

<h1>Delete Waiting Event</h1>

<div class="card">
    <h3>Are you sure you want to delete this?</h3>

    <dl>
        <dt>Name</dt>
        <dd>@Model.WaitingEvent.Name</dd>
        <dt>Occurrence Date</dt>
        <dd>@Model.WaitingEvent.OccurrenceDate.ToString("yyyy-MM-dd")</dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="WaitingEvent.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/WaitingEvents" class="btn btn-secondary">Cancel</a>
    </form>
</div>
