@page
@model CalendarManagementApi.Pages.WaitingEvents.IndexModel
@{
    ViewData["Title"] = "Waiting Events";
}

<h1>Waiting Events</h1>

<p>
    <a href="/WaitingEvents/Create" class="btn btn-success">Create New</a>
</p>

@if (Model.WaitingEvents.Any())
{
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Occurrence Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.WaitingEvents)
            {
                var isPastDue = item.OccurrenceDate <= DateOnly.FromDateTime(DateTime.Today);
                <tr>
                    <td>@item.Name</td>
                    <td>@item.OccurrenceDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        @if (isPastDue)
                        {
                            <span class="badge badge-warning">Past Due</span>
                        }
                        else
                        {
                            <span class="badge badge-success">Scheduled</span>
                        }
                    </td>
                    <td>
                        @if (isPastDue)
                        {
                            <form method="post" asp-page-handler="PostponeWeek" asp-route-id="@item.Id" style="display: inline;">
                                <button type="submit" class="btn btn-warning">+7 Days</button>
                            </form>
                            <form method="post" asp-page-handler="PostponeMonth" asp-route-id="@item.Id" style="display: inline;">
                                <button type="submit" class="btn btn-warning">+1 Month</button>
                            </form>
                        }
                        <a href="/WaitingEvents/Edit/@item.Id" class="btn btn-primary">Edit</a>
                        <a href="/WaitingEvents/Delete/@item.Id" class="btn btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No waiting events found. <a href="/WaitingEvents/Create">Create one</a>.</p>
}
