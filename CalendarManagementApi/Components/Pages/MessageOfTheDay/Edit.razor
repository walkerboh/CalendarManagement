@page "/messageoftheday/edit/{Id:int}"
@inject IMessageOfTheDayService MessageOfTheDayService
@inject NavigationManager Navigation

<PageTitle>Edit Message of the Day - Calendar Management</PageTitle>

<h1>Edit Message of the Day</h1>

@if (Motd == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <EditForm Model="Motd" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="form-group">
                <label for="message">Message</label>
                <InputText id="message" @bind-Value="Motd.Message" class="form-control" />
                <ValidationMessage For="() => Motd.Message" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="month">Month</label>
                <InputSelect id="month" @bind-Value="Motd.Month" class="form-control">
                    <option value="1">January</option>
                    <option value="2">February</option>
                    <option value="3">March</option>
                    <option value="4">April</option>
                    <option value="5">May</option>
                    <option value="6">June</option>
                    <option value="7">July</option>
                    <option value="8">August</option>
                    <option value="9">September</option>
                    <option value="10">October</option>
                    <option value="11">November</option>
                    <option value="12">December</option>
                </InputSelect>
                <ValidationMessage For="() => Motd.Month" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="day">Day</label>
                <InputNumber id="day" @bind-Value="Motd.Day" class="form-control" min="1" max="31" />
                <ValidationMessage For="() => Motd.Day" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="textColor">Text Color</label>
                <InputSelect id="textColor" @bind-Value="Motd.TextColor" class="form-control">
                    <option value="@TextColor.Black">Black</option>
                    <option value="@TextColor.Red">Red</option>
                </InputSelect>
                <ValidationMessage For="() => Motd.TextColor" class="text-danger" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/messageoftheday" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private CalendarManagementApi.Models.MessageOfTheDay? Motd { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Motd = await MessageOfTheDayService.GetByIdAsync(Id);
        if (Motd == null)
        {
            Navigation.NavigateTo("/messageoftheday");
        }
    }

    private async Task HandleSubmit()
    {
        if (Motd != null)
        {
            await MessageOfTheDayService.UpdateAsync(Motd);
            Navigation.NavigateTo("/messageoftheday");
        }
    }
}
