@page "/messageoftheday/delete/{Id:int}"
@inject IMessageOfTheDayService MessageOfTheDayService
@inject NavigationManager Navigation

<PageTitle>Delete Message of the Day - Calendar Management</PageTitle>

<h1>Delete Message of the Day</h1>

@if (Motd == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <h3>Are you sure you want to delete this?</h3>

        <dl>
            <dt>Message</dt>
            <dd>@Motd.Message</dd>
            <dt>Date</dt>
            <dd>@($"{Motd.Month:D2}/{Motd.Day:D2}")</dd>
        </dl>

        <button class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="/messageoftheday" class="btn btn-secondary">Cancel</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private CalendarManagement.Models.MessageOfTheDay? Motd { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Motd = await MessageOfTheDayService.GetByIdAsync(Id);
        if (Motd == null)
        {
            Navigation.NavigateTo("/messageoftheday");
        }
    }

    private async Task HandleDelete()
    {
        await MessageOfTheDayService.DeleteAsync(Id);
        Navigation.NavigateTo("/messageoftheday");
    }
}
