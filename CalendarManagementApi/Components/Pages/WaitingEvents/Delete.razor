@page "/waitingevents/delete/{Id:int}"
@inject IWaitingEventService WaitingEventService
@inject NavigationManager Navigation

<PageTitle>Delete Waiting Event - Calendar Management</PageTitle>

<h1>Delete Waiting Event</h1>

@if (WaitingEvent == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <h3>Are you sure you want to delete this?</h3>

        <dl>
            <dt>Name</dt>
            <dd>@WaitingEvent.Name</dd>
            <dt>Occurrence Date</dt>
            <dd>@WaitingEvent.OccurrenceDate.ToString("yyyy-MM-dd")</dd>
        </dl>

        <button class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="/waitingevents" class="btn btn-secondary">Cancel</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private WaitingEvent? WaitingEvent { get; set; }

    protected override async Task OnInitializedAsync()
    {
        WaitingEvent = await WaitingEventService.GetByIdAsync(Id);
        if (WaitingEvent == null)
        {
            Navigation.NavigateTo("/waitingevents");
        }
    }

    private async Task HandleDelete()
    {
        await WaitingEventService.DeleteAsync(Id);
        Navigation.NavigateTo("/waitingevents");
    }
}
