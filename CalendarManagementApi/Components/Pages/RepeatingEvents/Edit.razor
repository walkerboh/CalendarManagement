@page "/repeatingevents/edit/{Id:int}"
@inject IRepeatingEventService RepeatingEventService
@inject NavigationManager Navigation

<PageTitle>Edit Repeating Event - Calendar Management</PageTitle>

<h1>Edit Repeating Event</h1>

@if (RepeatingEvent == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <EditForm Model="RepeatingEvent" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="form-group">
                <label for="name">Name</label>
                <InputText id="name" @bind-Value="RepeatingEvent.Name" class="form-control" />
                <ValidationMessage For="() => RepeatingEvent.Name" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="image">Image</label>
                <InputText id="image" @bind-Value="RepeatingEvent.Image" class="form-control" maxlength="100" />
                <ValidationMessage For="() => RepeatingEvent.Image" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="repeatType">Repeat Type</label>
                <InputSelect id="repeatType" @bind-Value="RepeatingEvent.RepeatType" class="form-control">
                    <option value="@RepeatType.DayOfWeek">Day of Week</option>
                    <option value="@RepeatType.DayOfWeekOfMonth">Day of Week of Month</option>
                    <option value="@RepeatType.Interval">Interval</option>
                    <option value="@RepeatType.Date">Date (Yearly)</option>
                </InputSelect>
                <ValidationMessage For="() => RepeatingEvent.RepeatType" class="text-danger" />
            </div>

            @if (ShowDayOfWeek)
            {
                <div class="form-group">
                    <label for="dayOfWeek">Day of Week</label>
                    <InputSelect id="dayOfWeek" @bind-Value="RepeatingEvent.DayOfWeek" class="form-control">
                        <option value="">-- Select --</option>
                        <option value="0">Sunday</option>
                        <option value="1">Monday</option>
                        <option value="2">Tuesday</option>
                        <option value="3">Wednesday</option>
                        <option value="4">Thursday</option>
                        <option value="5">Friday</option>
                        <option value="6">Saturday</option>
                    </InputSelect>
                    <ValidationMessage For="() => RepeatingEvent.DayOfWeek" class="text-danger" />
                </div>
            }

            @if (ShowWeeksOfMonth)
            {
                <div class="form-group">
                    <label for="weeksOfMonth">Weeks of Month</label>
                    <InputText id="weeksOfMonth" @bind-Value="RepeatingEvent.WeeksOfMonth" class="form-control" placeholder="e.g., 1,3 for 1st and 3rd week" />
                    <small>Enter comma-separated week numbers (1-5)</small>
                    <ValidationMessage For="() => RepeatingEvent.WeeksOfMonth" class="text-danger" />
                </div>
            }

            @if (ShowInterval)
            {
                <div class="form-group">
                    <label for="intervalDays">Interval (Days)</label>
                    <InputNumber id="intervalDays" @bind-Value="RepeatingEvent.IntervalDays" class="form-control" min="1" />
                    <ValidationMessage For="() => RepeatingEvent.IntervalDays" class="text-danger" />
                </div>

                <div class="form-group">
                    <label for="startDate">Start Date</label>
                    <InputDate id="startDate" @bind-Value="RepeatingEvent.StartDate" class="form-control" />
                    <ValidationMessage For="() => RepeatingEvent.StartDate" class="text-danger" />
                </div>
            }

            @if (ShowDate)
            {
                <div class="form-group">
                    <label for="month">Month</label>
                    <InputSelect id="month" @bind-Value="RepeatingEvent.Month" class="form-control">
                        <option value="">-- Select --</option>
                        <option value="1">January</option>
                        <option value="2">February</option>
                        <option value="3">March</option>
                        <option value="4">April</option>
                        <option value="5">May</option>
                        <option value="6">June</option>
                        <option value="7">July</option>
                        <option value="8">August</option>
                        <option value="9">September</option>
                        <option value="10">October</option>
                        <option value="11">November</option>
                        <option value="12">December</option>
                    </InputSelect>
                    <ValidationMessage For="() => RepeatingEvent.Month" class="text-danger" />
                </div>

                <div class="form-group">
                    <label for="day">Day</label>
                    <InputNumber id="day" @bind-Value="RepeatingEvent.Day" class="form-control" min="1" max="31" />
                    <ValidationMessage For="() => RepeatingEvent.Day" class="text-danger" />
                </div>
            }

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="/repeatingevents" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private RepeatingEvent? RepeatingEvent { get; set; }

    private bool ShowDayOfWeek => RepeatingEvent?.RepeatType == RepeatType.DayOfWeek || RepeatingEvent?.RepeatType == RepeatType.DayOfWeekOfMonth;
    private bool ShowWeeksOfMonth => RepeatingEvent?.RepeatType == RepeatType.DayOfWeekOfMonth;
    private bool ShowInterval => RepeatingEvent?.RepeatType == RepeatType.Interval;
    private bool ShowDate => RepeatingEvent?.RepeatType == RepeatType.Date;

    protected override async Task OnInitializedAsync()
    {
        RepeatingEvent = await RepeatingEventService.GetByIdAsync(Id);
        if (RepeatingEvent == null)
        {
            Navigation.NavigateTo("/repeatingevents");
        }
    }

    private async Task HandleSubmit()
    {
        if (RepeatingEvent != null)
        {
            await RepeatingEventService.UpdateAsync(RepeatingEvent);
            Navigation.NavigateTo("/repeatingevents");
        }
    }
}
