@page "/repeatingevents/delete/{Id:int}"
@inject IRepeatingEventService RepeatingEventService
@inject NavigationManager Navigation

<PageTitle>Delete Repeating Event - Calendar Management</PageTitle>

<h1>Delete Repeating Event</h1>

@if (RepeatingEvent == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <h3>Are you sure you want to delete this?</h3>

        <dl>
            <dt>Name</dt>
            <dd>@RepeatingEvent.Name</dd>
            <dt>Type</dt>
            <dd>@RepeatingEvent.RepeatType</dd>
            <dt>Schedule</dt>
            <dd>@GetScheduleDescription()</dd>
        </dl>

        <button class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="/repeatingevents" class="btn btn-secondary">Cancel</a>
    </div>
}

@code {
    private static readonly string[] DayNames = { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
    private static readonly string[] MonthNames = { "", "January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December" };

    [Parameter]
    public int Id { get; set; }

    private RepeatingEvent? RepeatingEvent { get; set; }

    protected override async Task OnInitializedAsync()
    {
        RepeatingEvent = await RepeatingEventService.GetByIdAsync(Id);
        if (RepeatingEvent == null)
        {
            Navigation.NavigateTo("/repeatingevents");
        }
    }

    private string GetScheduleDescription()
    {
        if (RepeatingEvent == null) return "Unknown";

        return RepeatingEvent.RepeatType switch
        {
            RepeatType.DayOfWeek => RepeatingEvent.DayOfWeek.HasValue
                ? $"Every {DayNames[RepeatingEvent.DayOfWeek.Value]}"
                : "Not configured",
            RepeatType.DayOfWeekOfMonth => RepeatingEvent.DayOfWeek.HasValue
                ? $"{DayNames[RepeatingEvent.DayOfWeek.Value]} on weeks {RepeatingEvent.WeeksOfMonth ?? "N/A"}"
                : "Not configured",
            RepeatType.Interval => RepeatingEvent.IntervalDays.HasValue && RepeatingEvent.StartDate.HasValue
                ? $"Every {RepeatingEvent.IntervalDays} days from {RepeatingEvent.StartDate.Value:yyyy-MM-dd}"
                : "Not configured",
            RepeatType.Date => RepeatingEvent.Month.HasValue && RepeatingEvent.Day.HasValue
                ? $"Every {MonthNames[RepeatingEvent.Month.Value]} {RepeatingEvent.Day}"
                : "Not configured",
            _ => "Unknown"
        };
    }

    private async Task HandleDelete()
    {
        await RepeatingEventService.DeleteAsync(Id);
        Navigation.NavigateTo("/repeatingevents");
    }
}
