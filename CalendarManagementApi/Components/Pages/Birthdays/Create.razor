@page "/birthdays/create"
@inject IBirthdayService BirthdayService
@inject NavigationManager Navigation

<PageTitle>Create Birthday - Calendar Management</PageTitle>

<h1>Create Birthday</h1>

<div class="card">
    <EditForm Model="Birthday" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary class="alert alert-danger" />

        <div class="form-group">
            <label for="name">Name</label>
            <InputText id="name" @bind-Value="Birthday.Name" class="form-control" />
            <ValidationMessage For="() => Birthday.Name" class="text-danger" />
        </div>

        <div class="form-group">
            <label for="month">Month</label>
            <InputSelect id="month" @bind-Value="Birthday.Month" class="form-control">
                <option value="1">January</option>
                <option value="2">February</option>
                <option value="3">March</option>
                <option value="4">April</option>
                <option value="5">May</option>
                <option value="6">June</option>
                <option value="7">July</option>
                <option value="8">August</option>
                <option value="9">September</option>
                <option value="10">October</option>
                <option value="11">November</option>
                <option value="12">December</option>
            </InputSelect>
            <ValidationMessage For="() => Birthday.Month" class="text-danger" />
        </div>

        <div class="form-group">
            <label for="day">Day</label>
            <InputNumber id="day" @bind-Value="Birthday.Day" class="form-control" min="1" max="31" />
            <ValidationMessage For="() => Birthday.Day" class="text-danger" />
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-success">Create</button>
            <a href="/birthdays" class="btn btn-secondary">Cancel</a>
        </div>
    </EditForm>
</div>

@code {
    private CalendarManagementApi.Models.Birthday Birthday { get; set; } = new() { Month = 1, Day = 1 };

    private async Task HandleSubmit()
    {
        await BirthdayService.CreateAsync(Birthday);
        Navigation.NavigateTo("/birthdays");
    }
}
