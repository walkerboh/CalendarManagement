@page "/birthdays/delete/{Id:int}"
@inject IBirthdayService BirthdayService
@inject NavigationManager Navigation

<PageTitle>Delete Birthday - Calendar Management</PageTitle>

<h1>Delete Birthday</h1>

@if (Birthday == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <h3>Are you sure you want to delete this?</h3>

        <dl>
            <dt>Name</dt>
            <dd>@Birthday.Name</dd>
            <dt>Date</dt>
            <dd>@($"{Birthday.Month:D2}/{Birthday.Day:D2}")</dd>
        </dl>

        <button class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="/birthdays" class="btn btn-secondary">Cancel</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private CalendarManagementApi.Models.Birthday? Birthday { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Birthday = await BirthdayService.GetByIdAsync(Id);
        if (Birthday == null)
        {
            Navigation.NavigateTo("/birthdays");
        }
    }

    private async Task HandleDelete()
    {
        await BirthdayService.DeleteAsync(Id);
        Navigation.NavigateTo("/birthdays");
    }
}
