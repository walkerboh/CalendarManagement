@page "/dateevents/delete/{Id:int}"
@inject IDateEventService DateEventService
@inject NavigationManager Navigation

<PageTitle>Delete Date Event - Calendar Management</PageTitle>

<h1>Delete Date Event</h1>

@if (DateEvent == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card">
        <h3>Are you sure you want to delete this?</h3>

        <dl>
            <dt>Name</dt>
            <dd>@DateEvent.Name</dd>
            <dt>Date</dt>
            <dd>@($"{DateEvent.Month:D2}/{DateEvent.Day:D2}")</dd>
        </dl>

        <button class="btn btn-danger" @onclick="HandleDelete">Delete</button>
        <a href="/dateevents" class="btn btn-secondary">Cancel</a>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private DateEvent? DateEvent { get; set; }

    protected override async Task OnInitializedAsync()
    {
        DateEvent = await DateEventService.GetByIdAsync(Id);
        if (DateEvent == null)
        {
            Navigation.NavigateTo("/dateevents");
        }
    }

    private async Task HandleDelete()
    {
        await DateEventService.DeleteAsync(Id);
        Navigation.NavigateTo("/dateevents");
    }
}
