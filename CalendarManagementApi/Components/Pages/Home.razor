@page "/"
@inject ICalendarService CalendarService
@inject IWaitingEventService WaitingEventService
@inject IBirthdayService BirthdayService

<PageTitle>Home - Calendar Management</PageTitle>

<h1>Calendar Management</h1>

<p>Welcome to the Calendar Management application. Use this system to manage different types of calendar events.</p>

@if (MotdEvents.Any())
{
    <div class="card" style="margin-top: 1.5rem; max-width: none; background-color: #fff9e6;">
        <h2>Message of the Day</h2>
        @foreach (var motd in MotdEvents)
        {
            <p style="font-size: 1.2rem; margin: 0.5rem 0; color: @(motd.Layer == CalendarManagement.Models.Layer.Red ? "red" : "black");">@motd.Name</p>
        }
    </div>
}

@if (TodaysBirthdays.Any())
{
    <div class="card" style="margin-top: 1.5rem; max-width: none; background-color: #f0e6ff;">
        <h2>Birthdays Today</h2>
        @foreach (var birthday in TodaysBirthdays)
        {
            <p style="font-size: 1.2rem; margin: 0.5rem 0;">@birthday.Name</p>
        }
    </div>
}

<div class="card" style="margin-top: 1.5rem; max-width: none; background-color: #e8f4fd;">
    <h2>Today's Events - @Today.ToString("dddd, MMMM d, yyyy")</h2>
    @if (TodaysEvents.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Event Name</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in TodaysEvents)
                {
                    <tr>
                        <td data-label="Event Name">@evt.Name</td>
                        <td data-label="Type">
                            <span class="badge badge-repeating">Repeating Event</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p>No events scheduled for today.</p>
    }
</div>

@if (DueWaitingEvents.Any())
{
    <div class="card" style="margin-top: 1.5rem; max-width: none; background-color: #fdf2e8;">
        <h2>Waiting Events Due</h2>
        <p>These waiting events are past their occurrence date and need to be rescheduled:</p>
        <table>
            <thead>
                <tr>
                    <th>Event Name</th>
                    <th>Original Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var evt in DueWaitingEvents)
                {
                    <tr>
                        <td data-label="Event Name">@evt.Name</td>
                        <td data-label="Original Date">@evt.OccurrenceDate.ToString("yyyy-MM-dd")</td>
                        <td data-label="Actions">
                            <button class="btn btn-warning" @onclick="() => PostponeWeek(evt.Id)">+7 Days</button>
                            <button class="btn btn-warning" @onclick="() => PostponeMonth(evt.Id)">+1 Month</button>
                            <input type="date" value="@GetPostponeDate(evt.Id).ToString("yyyy-MM-dd")" @onchange="(e) => SetPostponeDate(evt.Id, e)" />
                            <button class="btn btn-warning" @onclick="() => PostponeToDate(evt.Id)">Set Date</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="card-grid">
    <div class="card" style="max-width: none;">
        <h2>Messages of the Day</h2>
        <p>Messages that display on a specific date each year (e.g., birthdays, anniversaries).</p>
        <a href="/messageoftheday" class="btn btn-primary">Manage Messages of the Day</a>
    </div>

    <div class="card" style="max-width: none;">
        <h2>Waiting Events</h2>
        <p>Events that occur once and then need to be manually rescheduled after completion.</p>
        <a href="/waitingevents" class="btn btn-primary">Manage Waiting Events</a>
    </div>

    <div class="card" style="max-width: none;">
        <h2>Repeating Events</h2>
        <p>Events that repeat on a schedule (weekly, specific weeks, or at intervals).</p>
        <a href="/repeatingevents" class="btn btn-primary">Manage Repeating Events</a>
    </div>

    <div class="card" style="max-width: none;">
        <h2>Birthdays</h2>
        <p>Track birthdays by name and date.</p>
        <a href="/birthdays" class="btn btn-primary">Manage Birthdays</a>
    </div>
</div>

<div class="card" style="margin-top: 2rem; max-width: none;">
    <h2>API Endpoints</h2>
    <p>External applications can fetch events for a specific date using these endpoints:</p>

    <div style="margin-top: 1rem;">
        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">GET /api/calendar/{date}</h3>
        <p style="margin: 0.25rem 0;">Returns waiting events (past due) and repeating events that match the specified date.</p>
        <code style="background: #f4f4f4; padding: 0.5rem; display: block;">Example: /api/calendar/2024-12-25</code>
    </div>

    <div style="margin-top: 1rem;">
        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">GET /api/calendar/motd/{date}</h3>
        <p style="margin: 0.25rem 0;">Returns messages of the day that match the month and day of the specified date.</p>
        <code style="background: #f4f4f4; padding: 0.5rem; display: block;">Example: /api/calendar/motd/2024-12-25</code>
    </div>

    <div style="margin-top: 1rem;">
        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">GET /api/calendar/birthdays/{date}</h3>
        <p style="margin: 0.25rem 0;">Returns birthdays that match the month and day of the specified date.</p>
        <code style="background: #f4f4f4; padding: 0.5rem; display: block;">Example: /api/calendar/birthdays/2024-12-25</code>
    </div>

    <div style="margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid #ddd;">
        <h3 style="font-size: 1.1rem; margin-bottom: 0.5rem;">Test Endpoints</h3>
        <div class="form-group" style="margin-bottom: 1rem;">
            <label for="testDate">Select Date:</label>
            <input type="date" id="testDate" @bind="TestDate" class="form-control" style="max-width: 200px;" />
        </div>
        <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button class="btn btn-primary" @onclick="TestCalendarEndpoint">Test /api/calendar/{date}</button>
            <button class="btn btn-primary" @onclick="TestMotdEndpoint">Test /api/calendar/motd/{date}</button>
            <button class="btn btn-primary" @onclick="TestBirthdaysEndpoint">Test /api/calendar/birthdays/{date}</button>
        </div>

        @if (ApiTestResult != null)
        {
            <div style="margin-top: 1rem;">
                <strong>Request:</strong> <code>@ApiTestUrl</code>
                <pre style="background: #f4f4f4; padding: 1rem; margin-top: 0.5rem; overflow-x: auto; border-radius: 4px;">@ApiTestResult</pre>
            </div>
        }
    </div>
</div>

@code {
    private List<CalendarManagement.DTOs.CalendarEventDto> TodaysEvents { get; set; } = new();
    private List<CalendarManagement.DTOs.CalendarEventDto> MotdEvents { get; set; } = new();
    private List<CalendarManagement.Models.Birthday> TodaysBirthdays { get; set; } = new();
    private List<WaitingEvent> DueWaitingEvents { get; set; } = new();
    private Dictionary<int, DateOnly> PostponeDates { get; set; } = new();
    private DateOnly Today { get; set; }
    private DateTime TestDate { get; set; } = DateTime.Today;
    private string? ApiTestResult { get; set; }
    private string? ApiTestUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Today = DateOnly.FromDateTime(DateTime.Today);
        await LoadData();
    }

    private async Task LoadData()
    {
        var events = await CalendarService.GetEventsForDate(Today);
        MotdEvents = (await CalendarService.GetMotdForDate(Today)).ToList();
        TodaysEvents = events.Where(e => e.EventType == "RepeatingEvent").ToList();
        DueWaitingEvents = await WaitingEventService.GetDueEventsAsync();
        var allBirthdays = await BirthdayService.GetAllAsync();
        TodaysBirthdays = allBirthdays.Where(b => b.Month == Today.Month && b.Day == Today.Day).ToList();
    }

    private async Task PostponeWeek(int id)
    {
        await WaitingEventService.PostponeWeekAsync(id);
        await LoadData();
    }

    private async Task PostponeMonth(int id)
    {
        await WaitingEventService.PostponeMonthAsync(id);
        await LoadData();
    }

    private DateOnly GetPostponeDate(int id)
    {
        return PostponeDates.TryGetValue(id, out var date) ? date : DateOnly.FromDateTime(DateTime.Today.AddDays(1));
    }

    private void SetPostponeDate(int id, ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var date))
        {
            PostponeDates[id] = date;
        }
    }

    private async Task PostponeToDate(int id)
    {
        var date = GetPostponeDate(id);
        await WaitingEventService.PostponeToDateAsync(id, date);
        PostponeDates.Remove(id);
        await LoadData();
    }

    private async Task TestCalendarEndpoint()
    {
        var date = DateOnly.FromDateTime(TestDate);
        ApiTestUrl = $"GET /api/calendar/{date:yyyy-MM-dd}";
        var results = await CalendarService.GetEventsForDate(date);
        ApiTestResult = System.Text.Json.JsonSerializer.Serialize(results, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    private async Task TestMotdEndpoint()
    {
        var date = DateOnly.FromDateTime(TestDate);
        ApiTestUrl = $"GET /api/calendar/motd/{date:yyyy-MM-dd}";
        var results = await CalendarService.GetMotdForDate(date);
        ApiTestResult = System.Text.Json.JsonSerializer.Serialize(results, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    private async Task TestBirthdaysEndpoint()
    {
        var date = DateOnly.FromDateTime(TestDate);
        ApiTestUrl = $"GET /api/calendar/birthdays/{date:yyyy-MM-dd}";
        var results = await CalendarService.GetBirthdaysForDate(date);
        ApiTestResult = System.Text.Json.JsonSerializer.Serialize(results, new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }
}
