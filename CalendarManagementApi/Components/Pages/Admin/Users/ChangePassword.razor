@page "/admin/users/{UserId}/change-password"
@inject UserManager<IdentityUser> UserManager
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations

<PageTitle>Change Password - Calendar Management</PageTitle>

<h1>Change Password</h1>

@if (IsSelf)
{
    <p class="alert alert-danger">You cannot change your own password here.</p>
    <a href="/admin/users" class="btn btn-secondary">Back to Users</a>
}
else if (TargetUser is not null)
{
    <p>User: <strong>@TargetUser.UserName</strong></p>

    <div class="card">
        @if (Errors.Any())
        {
            <div class="alert alert-danger">
                <ul class="mb-0">
                    @foreach (var error in Errors)
                    {
                        <li>@error</li>
                    }
                </ul>
            </div>
        }

        <EditForm Model="Model" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary class="alert alert-danger" />

            <div class="form-group">
                <label for="password">New Password</label>
                <InputText id="password" type="password" @bind-Value="Model.Password" class="form-control" />
                <ValidationMessage For="() => Model.Password" class="text-danger" />
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm New Password</label>
                <InputText id="confirmPassword" type="password" @bind-Value="Model.ConfirmPassword" class="form-control" />
                <ValidationMessage For="() => Model.ConfirmPassword" class="text-danger" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-success">Save</button>
                <a href="/admin/users" class="btn btn-secondary">Cancel</a>
            </div>
        </EditForm>
    </div>
}
else
{
    <p>User not found. <a href="/admin/users">Back to Users</a>.</p>
}

@code {
    [Parameter] public string UserId { get; set; } = string.Empty;

    private IdentityUser? TargetUser { get; set; }
    private bool IsSelf { get; set; }
    private ChangePasswordModel Model { get; set; } = new();
    private List<string> Errors { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var currentUserId = UserManager.GetUserId(authState.User);
        IsSelf = currentUserId == UserId;
        if (!IsSelf)
            TargetUser = await UserManager.FindByIdAsync(UserId);
    }

    private async Task HandleSubmit()
    {
        Errors.Clear();
        var removeResult = await UserManager.RemovePasswordAsync(TargetUser!);
        if (!removeResult.Succeeded)
        {
            Errors = removeResult.Errors.Select(e => e.Description).ToList();
            return;
        }
        var addResult = await UserManager.AddPasswordAsync(TargetUser!, Model.Password);
        if (addResult.Succeeded)
        {
            Navigation.NavigateTo("/admin/users");
        }
        else
        {
            Errors = addResult.Errors.Select(e => e.Description).ToList();
        }
    }

    private sealed class ChangePasswordModel
    {
        [Required, MinLength(6)]
        public string Password { get; set; } = string.Empty;

        [Required, Compare(nameof(Password), ErrorMessage = "Passwords do not match.")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
