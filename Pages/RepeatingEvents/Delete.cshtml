@page "{id:int}"
@model CalendarManagementApi.Pages.RepeatingEvents.DeleteModel
@{
    ViewData["Title"] = "Delete Repeating Event";
    var dayNames = new[] { "Sunday", "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" };
}

<h1>Delete Repeating Event</h1>

<div class="card">
    <h3>Are you sure you want to delete this?</h3>

    <dl>
        <dt>Name</dt>
        <dd>@Model.RepeatingEvent.Name</dd>
        <dt>Type</dt>
        <dd>@Model.RepeatingEvent.RepeatType</dd>
        <dt>Schedule</dt>
        <dd>
            @switch (Model.RepeatingEvent.RepeatType)
            {
                case RepeatType.DayOfWeek:
                    @(Model.RepeatingEvent.DayOfWeek.HasValue ? $"Every {dayNames[Model.RepeatingEvent.DayOfWeek.Value]}" : "Not configured")
                    break;
                case RepeatType.DayOfWeekOfMonth:
                    var weeks = Model.RepeatingEvent.WeeksOfMonth ?? "N/A";
                    @(Model.RepeatingEvent.DayOfWeek.HasValue ? $"{dayNames[Model.RepeatingEvent.DayOfWeek.Value]} on weeks {weeks}" : "Not configured")
                    break;
                case RepeatType.Interval:
                    @(Model.RepeatingEvent.IntervalDays.HasValue && Model.RepeatingEvent.StartDate.HasValue
                        ? $"Every {Model.RepeatingEvent.IntervalDays} days from {Model.RepeatingEvent.StartDate.Value:yyyy-MM-dd}"
                        : "Not configured")
                    break;
            }
        </dd>
    </dl>

    <form method="post">
        <input type="hidden" asp-for="RepeatingEvent.Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a href="/RepeatingEvents" class="btn btn-secondary">Cancel</a>
    </form>
</div>
