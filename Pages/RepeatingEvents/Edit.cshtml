@page "{id:int}"
@model CalendarManagementApi.Pages.RepeatingEvents.EditModel
@{
    ViewData["Title"] = "Edit Repeating Event";
}

<h1>Edit Repeating Event</h1>

<div class="card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input type="hidden" asp-for="RepeatingEvent.Id" />

        <div class="form-group">
            <label asp-for="RepeatingEvent.Name"></label>
            <input asp-for="RepeatingEvent.Name" class="form-control" />
            <span asp-validation-for="RepeatingEvent.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="RepeatingEvent.RepeatType"></label>
            <select asp-for="RepeatingEvent.RepeatType" class="form-control" id="repeatType">
                <option value="0">Day of Week</option>
                <option value="1">Day of Week of Month</option>
                <option value="2">Interval</option>
            </select>
            <span asp-validation-for="RepeatingEvent.RepeatType" class="text-danger"></span>
        </div>

        <div class="form-group" id="dayOfWeekGroup">
            <label asp-for="RepeatingEvent.DayOfWeek">Day of Week</label>
            <select asp-for="RepeatingEvent.DayOfWeek" class="form-control">
                <option value="">-- Select --</option>
                <option value="0">Sunday</option>
                <option value="1">Monday</option>
                <option value="2">Tuesday</option>
                <option value="3">Wednesday</option>
                <option value="4">Thursday</option>
                <option value="5">Friday</option>
                <option value="6">Saturday</option>
            </select>
            <span asp-validation-for="RepeatingEvent.DayOfWeek" class="text-danger"></span>
        </div>

        <div class="form-group" id="weeksOfMonthGroup" style="display: none;">
            <label asp-for="RepeatingEvent.WeeksOfMonth">Weeks of Month</label>
            <input asp-for="RepeatingEvent.WeeksOfMonth" class="form-control" placeholder="e.g., 1,3 for 1st and 3rd week" />
            <small>Enter comma-separated week numbers (1-5)</small>
            <span asp-validation-for="RepeatingEvent.WeeksOfMonth" class="text-danger"></span>
        </div>

        <div class="form-group" id="intervalDaysGroup" style="display: none;">
            <label asp-for="RepeatingEvent.IntervalDays">Interval (Days)</label>
            <input asp-for="RepeatingEvent.IntervalDays" class="form-control" type="number" min="1" />
            <span asp-validation-for="RepeatingEvent.IntervalDays" class="text-danger"></span>
        </div>

        <div class="form-group" id="startDateGroup" style="display: none;">
            <label asp-for="RepeatingEvent.StartDate">Start Date</label>
            <input asp-for="RepeatingEvent.StartDate" class="form-control" type="date" />
            <span asp-validation-for="RepeatingEvent.StartDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/RepeatingEvents" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

<script>
    document.getElementById('repeatType').addEventListener('change', function() {
        var type = this.value;
        var dayOfWeekGroup = document.getElementById('dayOfWeekGroup');
        var weeksOfMonthGroup = document.getElementById('weeksOfMonthGroup');
        var intervalDaysGroup = document.getElementById('intervalDaysGroup');
        var startDateGroup = document.getElementById('startDateGroup');

        // Reset all to hidden
        dayOfWeekGroup.style.display = 'none';
        weeksOfMonthGroup.style.display = 'none';
        intervalDaysGroup.style.display = 'none';
        startDateGroup.style.display = 'none';

        if (type === '0') { // DayOfWeek
            dayOfWeekGroup.style.display = 'block';
        } else if (type === '1') { // DayOfWeekOfMonth
            dayOfWeekGroup.style.display = 'block';
            weeksOfMonthGroup.style.display = 'block';
        } else if (type === '2') { // Interval
            intervalDaysGroup.style.display = 'block';
            startDateGroup.style.display = 'block';
        }
    });

    // Trigger on page load
    document.getElementById('repeatType').dispatchEvent(new Event('change'));
</script>
