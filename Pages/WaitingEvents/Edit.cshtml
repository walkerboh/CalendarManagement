@page "{id:int}"
@model CalendarManagementApi.Pages.WaitingEvents.EditModel
@{
    ViewData["Title"] = "Edit Waiting Event";
}

<h1>Edit Waiting Event</h1>

<div class="card">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <input type="hidden" asp-for="WaitingEvent.Id" />

        <div class="form-group">
            <label asp-for="WaitingEvent.Name"></label>
            <input asp-for="WaitingEvent.Name" class="form-control" />
            <span asp-validation-for="WaitingEvent.Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="WaitingEvent.OccurrenceDate"></label>
            <input asp-for="WaitingEvent.OccurrenceDate" class="form-control" type="date" />
            <span asp-validation-for="WaitingEvent.OccurrenceDate" class="text-danger"></span>
        </div>

        <div class="form-group">
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="/WaitingEvents" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
